{
  "name": "gutty-agente",
  "productName": "Gutty Agente",
  "version": "1.0.0",
  "description": "Gutty Agente — gerenciador local de dispositivos (TEF, impressoras, balancas) integrado ao Gutty Web",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "esbuild renderer/main.tsx --bundle --outfile=dist/renderer/main.js --loader:.tsx=tsx --loader:.ts=ts --jsx=automatic --platform=browser --target=es2022 --minify",
    "build:css": "tailwindcss -i renderer/styles.css -o dist/renderer/styles.css --minify",
    "build:html": "node -e \"require('fs').copyFileSync('renderer/index.html', 'dist/renderer/index.html')\"",
    "build:assets": "node -e \"const fs=require('fs');if(!fs.existsSync('renderer/assets'))process.exit(0);fs.cpSync('renderer/assets','dist/renderer/assets',{recursive:true,force:true});console.log('assets copiados (recursive)');\"",
    "build": "npm run build:electron && npm run build:renderer && npm run build:css && npm run build:html && npm run build:assets",
    "dev": "npm run build && electron dist/electron/main.js",
    "pack:payload": "node pack.js",
    "pack:installer": "powershell -ExecutionPolicy Bypass -File installer/build-installer.ps1",
    "pack": "npm run pack:payload && npm run pack:installer",
    "test:installer": "node dev-local.js",
    "test:installer:fast": "node dev-local.js --fast",
    "run:exe": "powershell -NoProfile -Command \"& '.\\bin\\GuttyAgente-win32-x64\\GuttyAgente.exe'\"",
    "deploy:release": "node deploy-to-public.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "node-stream-zip": "^1.15.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.23",
    "electron": "^32.2.6",
    "esbuild": "^0.25.1",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
